{
  "harness": "opencode",
  "launch": ["opencode"],
  "boot_artifact": "AGENTS.md",
  "emit": ["opencode.json"],
  "env": { "OPENCODE_DISABLE_CLAUDE_CODE": "1" },
  "model": { "file": "opencode.json", "key": "model" },
  "headless": { "launch": ["opencode", "run"], "model_flag": "-m" },
  "sandbox": {
    "merge_json": {
      "opencode.json": {
        "permission": { "bash": "allow" }
      }
    }
  }
}
