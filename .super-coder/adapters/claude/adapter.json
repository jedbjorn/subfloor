{
  "harness": "claude",
  "launch": ["claude"],
  "boot_artifact": "CLAUDE.md",
  "emit": [],
  "env": {},
  "model": { "flag": "--model" },
  "merge_json": {
    ".claude/settings.local.json": {
      "hooks": {
        "PreToolUse": [
          {
            "matcher": "Edit|Write|NotebookEdit|MultiEdit",
            "hooks": [
              {
                "type": "command",
                "command": "bash \"$CLAUDE_PROJECT_DIR/.super-coder/scripts/branch-guard.sh\""
              }
            ]
          }
        ]
      }
    }
  },
  "sandbox": {
    "merge_json": {
      ".claude/settings.json": {
        "permissions": { "defaultMode": "acceptEdits" }
      }
    }
  }
}
