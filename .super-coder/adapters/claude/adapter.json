{
  "harness": "claude",
  "launch": ["claude"],
  "boot_artifact": "CLAUDE.md",
  "emit": [],
  "env": {},
  "model": { "flag": "--model" },
  "name": { "flag": "--name" },
  "headless": { "launch": ["claude", "-p"], "model_flag": "--model" },
  "merge_json": {
    ".claude/settings.local.json": {
      "hooks": {
        "PreToolUse": [
          {
            "matcher": "Edit|Write|NotebookEdit|MultiEdit",
            "hooks": [
              {
                "type": "command",
                "command": "bash -c 'eng=\"${SC_ENGINE_DIR:-$(cd \"$(git rev-parse --git-common-dir 2>/dev/null)/..\" 2>/dev/null && pwd)/.super-coder}\"; exec bash \"$eng/scripts/branch-guard.sh\"'"
              }
            ]
          }
        ],
        "SessionEnd": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "bash -c 'eng=\"${SC_ENGINE_DIR:-$(cd \"$(git rev-parse --git-common-dir 2>/dev/null)/..\" 2>/dev/null && pwd)/.super-coder}\"; exec bash \"$eng/scripts/telemetry-hook.sh\"'"
              }
            ]
          }
        ]
      }
    }
  },
  "sandbox": {
    "env": { "IS_SANDBOX": "1" },
    "merge_json": {
      ".claude/settings.local.json": {
        "permissions": { "defaultMode": "bypassPermissions" },
        "skipDangerousModePermissionPrompt": true
      }
    },
    "headless_flags": ["--dangerously-skip-permissions"]
  }
}
