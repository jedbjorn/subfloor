#!/bin/sh
# super-coder auto-remap — keep the dr_* catalogue fresh after a pull/merge.
# Tracked hook, fired via core.hooksPath (wired by `./sc map-setup`). Owned by
# the cartographer; no working shell maps. Best-effort: a map failure must never
# block the git operation.
root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
[ -x "$root/sc" ] || exit 0
( cd "$root" && ./sc map >/dev/null 2>&1 ) || true
exit 0
