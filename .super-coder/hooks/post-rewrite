#!/bin/sh
# super-coder auto-remap — keep the dr_* catalogue fresh after a rebase/amend.
# Tracked hook, fired via core.hooksPath (wired by `./sc map-setup`). Owned by
# the cartographer; no working shell maps. Best-effort: never block the rewrite.
# (git feeds the rewritten refs on stdin; we don't need them — just remap.)
root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
[ -x "$root/sc" ] || exit 0
( cd "$root" && ./sc map >/dev/null 2>&1 ) || true
exit 0
