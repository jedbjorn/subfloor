# super-coder — the .db is rebuilt from git-tracked text (schema + migrations +
# snapshot). Never commit it: binary churn + merge hell, fatal with parallel shells.
.super-coder/shell_db.db
.super-coder/shell_db.db-wal
.super-coder/shell_db.db-shm

# Boot artifact — rebuilt at launch from the DB. The harness dictates the name;
# we dual-write both. Ignored everywhere. opencode.json is emitted from the
# OpenCode adapter template each launch (same deal).
/CLAUDE.md
/AGENTS.md
/opencode.json

# Per-shell skill render — .claude/skills/<name>/SKILL.md, rebuilt at boot for
# whichever shell launches (harness-consumed cache, like the boot artifact).
# Only the render output is ignored; a fork's own .claude/settings stays tracked.
/.claude/skills/

# Allow-all trust override, written at boot (Claude's local, gitignored-by-
# convention settings file). A launch artifact like the boot doc — never tracked,
# so it can't clobber a fork's committed .claude/settings.json.
/.claude/settings.local.json

# Per-instance local config — derived ports etc. Local to this fork, never
# propagates (re-derived from the repo path if absent). Hand-overridable.
/.super-coder/instance.json

# Backgrounded review-GUI pid + log (./sc launch → ./sc down / ./sc logs).
/.super-coder/run/

# Python / tooling
__pycache__/
*.pyc
.venv/
node_modules/
.svelte-kit/
